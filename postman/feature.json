      "name": "Ok",
      "item": [
        {
          "name": "Public: Получение комментариев для события",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Проверка кода ответа\", function() {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}/comments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events",
                "{{eventId}}",
                "comments"
              ]
            },
            "description": "Получение всех комментариев для конкретного события"
          },
          "response": []
        },
        {
          "name": "Private: Получение списка своих комментариев",
          "request": {
            "method": "GET",
            "header": [],
