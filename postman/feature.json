            },
            "url": {
              "raw": "{{baseUrl}}/users/{{initiatorId}}/events/{{eventId}}/comments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{initiatorId}}",
                "events",
                "{{eventId}}",
                "comments"
              ]
            },
            "description": "Модерация комментариев на событие (подтверждение или отклонение)"
          },
          "response": []
        }
